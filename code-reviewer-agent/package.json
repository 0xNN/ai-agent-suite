{
  "name": "code-reviewer-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "code-reviewer-agent": "./scripts/ai-code-reviewer.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "review": "node scripts/ai-code-reviewer.mjs",
    "review:dry-run": "node scripts/ai-code-reviewer.mjs --dry-run",
    "typecheck": "tsc --noEmit",
    "build": "npm run review && npm run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "axios": "^1.18.0"
  }
}
